# Telegram
TELEGRAM_BOT_TOKEN=

# LLM
ANTHROPIC_API_KEY=

# Whisper (OpenAI)
OPENAI_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://astrobot:astrobot_password@postgres:5432/astrobot
DATABASE_URL_SYNC=postgresql://astrobot:astrobot_password@postgres:5432/astrobot

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Encryption
AES_ENCRYPTION_KEY=

# Payments
CRYPTO_BOT_TOKEN=

# Admin API
SECRET_KEY=

# App
LOG_LEVEL=info
SESSION_TIMEOUT_MINUTES=30
FREE_TRIAL_MESSAGES_DAILY=50
FREE_TRIAL_MESSAGES_WEEKLY=200
FREE_TRIAL_CUMULATIVE_SECONDS=3600
ASTROBOT_HOST=0.0.0.0
ASTROBOT_PORT=8000

# Postgres (for Docker Compose)
POSTGRES_USER=astrobot
POSTGRES_PASSWORD=astrobot_password
POSTGRES_DB=astrobot

# Local dev only — sudo password (не заполнять, только в .env)
SUDO_PASSWORD=
